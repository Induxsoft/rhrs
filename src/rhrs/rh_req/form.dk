#include "dkli.dkh"
#!
module "form.dk"
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "uielements.v12.dkl"
    #include "../_lib/config.dk"
    #include "../_lib/lib.dk"
	#include "../_lib/icons.dk"

    do @context.begin(@crud_context)

    ref @_GET = ifnull(@("&parameters"),record.create())
    ref entity = ifnull(@("&./entity"),record.create())
    ref detail = ifnull(@("&./detail"),list.create())

	@_entities_type = @("$parameters/_entities_type")
	@_entity_id = @("$parameters/_entity_id")

	is_new = (@_entity_id == "_new")
    cur_status = @@(entity,"#ref_status")
    
    @show_btn_aprobar = (cur_status == @stt_req_pendiente)
    @show_btn_cancelar = (cur_status == @stt_req_aprobada)
    @enable_editing = (is_new || cur_status == @stt_req_pendiente)

    do lib.fix_data_array(detail,10)

    fn_print_buttons::
    {
        act_btn_cls = "btn btn-sm border-secondary induxsoft-corners btn-main-action no-print"
        
        #$
        button(class="#<act_btn_cls>" type="button" id="btn_guardar" "data-status"="#<@stt_req_pendiente>" title="Guardar"){$"#<@ICON_SAVE>"}
        #!

        if @show_btn_aprobar {#$ button(class="#<act_btn_cls>" type="button" id="btn_aprobar" "data-status"="#<@stt_req_aprobada>" title="Aprobar"){$"#<@ICON_CHECK>"} #!}
        if @show_btn_cancelar {#$ button(class="#<act_btn_cls>" type="button" id="btn_cancelar" "data-status"="#<@stt_req_cancelada>" title="Cancelar"){$"#<@ICON_TRASH>"} #!}
    }
    point print_buttons to fn_print_buttons

    new nav_config
    {
        @"title": ifstr(is_new, "Nuevo", @@(entity,"$referencia"))
        @"buttons*": print_buttons
        @"urlexit": "../"
        member @"hidden" { @"print": @true }
    }

    #$
    div(class="container")
    {
        #!
        do uie.printV12FormBar(nav_config)
        #$
        link(href="#<@CSS_MAIN>" rel="stylesheet")
        
        div(class="container-section #<ifstr(not(@enable_editing),'disabled-all','')>" id="work_area")
        {
            div(class="alert alert-danger overflow-auto mb-2 #<ifstr(@('$error/message')!='','','d-none')>" id="frm_alerts"){$"#<@('error/message')>"}

            form(method="POST" action="./" id="frm_reqper")
            {
                input(type="hidden" name="sys_pk" value="#<@@(entity, '#sys_pk')>")
                input(type="hidden" name="sys_recver" value="#<@@(entity, '#sys_recver')>")

                div(class="row gx-2")
                {
                    div(class="col-lg-3 col-md-3 col-sm-3")
                    {
                        label(class="form-label fw-bold" "for"="txt_referencia"){$"Referencia:"}
                        input(class="form-control form-control-sm rounded-0" type="text" name="referencia" value="#<lib.form('referencia','tx',entity)>" id="txt_referencia" minlength="4" maxlength="32" size="32" required="")
                    }
                    div(class="col-lg-3 col-md-3 col-sm-3")
                    {
                        label(class="form-label" "for"="txt_fecha"){$"Fecha:"}
                        input(class="form-control form-control-sm rounded-0" type="date" name="fecha" value="#<lib.form('fecha','dt',entity)>" id="txt_fecha")
                    }
                    div(class="col-lg-3 col-md-3 col-sm-3")
                    {
                        label(class="form-label" "for"="txt_flimite"){$"F. Limite:"}
                        input(class="form-control form-control-sm rounded-0" type="date" name="flimite" value="#<lib.form('flimite','dt',entity)>" id="txt_flimite")
                    }
                    div(class="col-12")
                    {
                        label(class="form-label" "for"="txt_notas"){$"Notas:"}
                        textarea(class="form-control rounded-0" name="notas" id="txt_notas" rows="4" maxlength="32000"){ $"#<lib.form('notas','tx',entity)>" }
                    }
                }
            }

            div(class="d-flex justify-content-end align-items-center border-top gap-1 px-2 my-2" id="tbl_action_bar")
            {
                small(class="flex-grow-1 text-muted"){$"Seleccione los puestos en la cuadrícula"}

                button(class="btn btn-sm rounded-0" type="button" id="btn_add_row" title="Agregar fila"){$"#<@ICON_ADD_ROW> Agregar"}
                button(class="btn btn-sm rounded-0" type="button" id="btn_del_row" title="Eliminar fila"){$"#<@ICON_REMOVE_ROW> Eliminar"}
            }
            div(class="alert alert-danger rounded-0 mb-1 py-0 d-none" role="alert" id="tbl_alerts"){$""}
            div(class="" id="div_tbl_puestos" style="width:auto; min-width:100%; max-height:55vh; display:flex;")
            {
                "edit-table"(id="tbl_puestos" data="#<to.json(detail)>" "auto-confirm"="true" style="width:100%;"
                "row-height"="1.2rem"
                "control-styles"="
                    tr th { font-size:.9rem; outline:none !important; font-weight:500 !important; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; -o-text-overflow:ellipsis; }
                    tr td { font-size:.8rem; }
                    #__table_input { font-size:unset !important; }
                ")
                {
                    "edit-thead"
                    {
                        "edit-tr"
                        {
                            "edit-th"(type="Text" field="dpuesto" button="true"){$"Puesto"}
                            "edit-th"(type="NoEditable" field="dunidad"){$"Unidad"}
                            "edit-th"(type="Number" field="cant_solicitada" textalign="center"){$"Cant. Solicitada"}
                            "edit-th"(type="NoEditable" field="cant_aprobada" textalign="center"){$"Cant. Aprobada"}
                            #! if cur_status == @stt_req_aprobada
                            {
                                #$ "edit-th"(type="NoEditable" field="cant_contratada" textalign="center"){$"Cant. Contratada"}
                            }
                            "edit-th"(type="Memo" field="notas"){$"Notas"}
                        }
                    }
                }
            }

            div
            {
                "input-key"(id="ik_puesto" "data-key"="sys_pk" "data-search"="codigo" "data-text"="descripcion" "data-source"="#<@URL_BUSCAR_PUESTO>" columns="codigo,descripcion,unidad_org" colcaptions="Código,Descripción,Unidad Organizacional" "control-styles"="#container{display:none !important;}"){$""}
            }
        }

        script(src="#<@JS_MAIN>"){$""}
        script(src="#<@JS_RH_REQ>"){$""}
        script(type="text/javascript")
        {$'
            document.addEventListener("DOMContentLoaded", () => {
                reqper.formId = "frm_reqper";
                reqper.tableId = "tbl_puestos";
                reqper.url_exit = "#<@RH_REQPER>";
                reqper.cur_status = #<cur_status>;
                reqper.init();
            });
        '}
    }
}